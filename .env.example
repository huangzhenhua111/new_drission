# 默认使用你指定的主力多模态模型。
# 兼容旧项目变量名：VISION_LLM_API_KEY / VISION_LLM_BASE_URL / VISION_LLM_MODEL。
MULTIMODAL_MODEL=qwen3.7-plus
MULTIMODAL_API_KEY=
MULTIMODAL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 纯文本需求解析可单独配置；不配置时会复用 MULTIMODAL_*。
TEXT_MODEL=deepseek-v4-pro
TEXT_API_KEY=
TEXT_BASE_URL=https://api.deepseek.com

# 浏览器配置
BROWSER_HEADLESS=false
BROWSER_USER_DATA_DIR=.browser_profile

